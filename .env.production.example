# Application Environment
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
PYTHONPATH=/app
TZ=UTC

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_TIMEOUT=120

# Model Service
MODEL_SERVICE_HOST=0.0.0.0
MODEL_SERVICE_PORT=8001
MODEL_CHECKPOINT_PATH=/app/checkpoints/latest.pt
CUDA_VISIBLE_DEVICES=0
MODEL_BATCH_SIZE=32
MODEL_MAX_QUEUE_SIZE=100

# Database Configuration
DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=bitcoin_trading
DB_USER=your-db-user
DB_PASSWORD=your-secure-password
DB_SSL_MODE=require
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
REDIS_SSL=true

# Security
JWT_SECRET=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
ALLOWED_HOSTS=api.your-domain.com,model.your-domain.com
CORS_ORIGINS=https://your-domain.com
API_KEY_HASH=your-api-key-hash

# SSL/TLS
SSL_CERT_PATH=/etc/letsencrypt/live/your-domain.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/your-domain.com/privkey.pem

# API Keys
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret
NEWSAPI_KEY=your-newsapi-key
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret

# Monitoring
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus-multiproc
GRAFANA_ADMIN_PASSWORD=your-grafana-admin-password
PROMETHEUS_AUTH_USERNAME=prometheus
PROMETHEUS_AUTH_PASSWORD=your-prometheus-password

# Backup Configuration
BACKUP_BUCKET=your-backup-bucket
BACKUP_RETENTION_DAYS=30
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_DEFAULT_REGION=us-east-1
AWS_BACKUP_KMS_KEY=your-kms-key-id

# Alerting
SLACK_WEBHOOK_URL=your-slack-webhook-url
ALERT_EMAIL=alerts@your-domain.com
PAGERDUTY_SERVICE_KEY=your-pagerduty-key

# Performance Tuning
WORKER_CLASS=uvicorn.workers.UvicornWorker
WORKER_CONNECTIONS=1000
KEEPALIVE=65
TIMEOUT=120
GRACEFUL_TIMEOUT=30
MAX_REQUESTS=10000
MAX_REQUESTS_JITTER=1000

# Resource Limits
MAX_MEMORY=2G
MAX_CPU=1.0
GPU_MEMORY_FRACTION=0.9

# Feature Flags
ENABLE_SENTIMENT_ANALYSIS=true
ENABLE_REAL_TIME_PREDICTIONS=true
ENABLE_AUTO_SCALING=true
ENABLE_CACHE=true
ENABLE_RATE_LIMITING=true

# Cache Configuration
CACHE_TYPE=redis
CACHE_REDIS_HOST=redis
CACHE_REDIS_PORT=6379
CACHE_DEFAULT_TIMEOUT=300
CACHE_KEY_PREFIX=prod

# Rate Limiting
RATELIMIT_STORAGE_URL=redis://redis:6379/1
RATELIMIT_STRATEGY=fixed-window
RATELIMIT_DEFAULT=300/hour

# Logging Configuration
LOG_FORMAT=json
LOG_FILE=/var/log/app/application.log
LOG_ROTATION=1d
LOG_RETENTION=30d
SENTRY_DSN=your-sentry-dsn
ENABLE_ACCESS_LOG=true

# Metrics Collection
COLLECT_CUSTOM_METRICS=true
METRICS_INTERVAL=15
ENABLE_PROFILING=false

# Health Checks
HEALTH_CHECK_INTERVAL=30
ENABLE_DEEP_HEALTH_CHECK=true

# Documentation
ENABLE_DOCS=false
DOCS_URL=null
REDOC_URL=null

# Cleanup
CLEANUP_INTERVAL=86400
CLEANUP_THRESHOLD_DAYS=7

# Development Tools (disabled in production)
ENABLE_DEBUG_TOOLBAR=false
ENABLE_SWAGGER=false
