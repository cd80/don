# Application Settings
ENVIRONMENT=production
LOG_LEVEL=INFO
DEBUG=false

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_TIMEOUT=60

# Database Settings
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Exchange API Keys
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
KRAKEN_API_KEY=your_kraken_api_key
KRAKEN_API_SECRET=your_kraken_api_secret
COINBASE_API_KEY=your_coinbase_api_key
COINBASE_API_SECRET=your_coinbase_api_secret

# Trading Settings
MAX_POSITION_SIZE=1.0
RISK_LIMIT=0.02
MIN_PROFIT_THRESHOLD=0.001
EXECUTION_TIMEOUT=0.1
UPDATE_INTERVAL=0.001

# Risk Management
MAX_DRAWDOWN=0.02
STOP_LOSS_THRESHOLD=0.02
TAKE_PROFIT_THRESHOLD=0.05
POSITION_TIMEOUT=300

# Monitoring
PROMETHEUS_HOST=prometheus
PROMETHEUS_PORT=9090
GRAFANA_HOST=grafana
GRAFANA_PORT=3000
ALERTMANAGER_HOST=alertmanager
ALERTMANAGER_PORT=9093

# Notifications
SLACK_WEBHOOK_URL=your_slack_webhook_url
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=rkwk0112@gmail.com
EMAIL_PASSWORD=your_email_password
NOTIFICATION_RECIPIENTS=rkwk0112@gmail.com

# AWS Settings (for backups)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-northeast-2
BACKUP_BUCKET=your_backup_bucket_name

# Security
JWT_SECRET_KEY=your_jwt_secret_key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Model Service
MODEL_HOST=model_service
MODEL_PORT=5000
MODEL_TIMEOUT=30

# Documentation
DOCS_URL=https://cd80.github.io/don

# Maintainer Info
MAINTAINER_NAME=Kim, Sungwoo
MAINTAINER_EMAIL=rkwk0112@gmail.com
GITHUB_REPO=https://github.com/cd80/don.git

# Note: Replace all "your_*" values with actual production values
# Never commit the actual .env.production file with real credentials
